{
  "name": "@paramission-lab/phantom",
  "version": "1.0.3",
  "description": "Blazing-fast RGBA image processing for massive resolutions — tiles, WebGPU, WASM, and AI mask removal, zero full-frame allocations.",
  "author": {
    "name": "Paramission Lab",
    "url": "https://github.com/ParamissionLab"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ParamissionLab/phantom.git"
  },
  "homepage": "https://github.com/ParamissionLab/phantom#readme",
  "bugs": {
    "url": "https://github.com/ParamissionLab/phantom/issues"
  },
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gpu": {
      "types": "./dist/gpu/index.d.ts",
      "import": "./dist/gpu/index.js"
    },
    "./workers": {
      "types": "./dist/workers/index.d.ts",
      "import": "./dist/workers/index.js"
    },
    "./worker": {
      "types": "./dist/workers/tile-worker.d.ts",
      "import": "./dist/workers/tile-worker.js"
    },
    "./workers/tile-worker": {
      "types": "./dist/workers/tile-worker.d.ts",
      "import": "./dist/workers/tile-worker.js"
    },
    "./wasm": {
      "types": "./dist/wasm/index.d.ts",
      "import": "./dist/wasm/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run ci && npm run demo:build",
    "build:wasm": "zig build-exe zig/src/phantom-kernel.zig -target wasm32-freestanding -fno-entry -rdynamic -O ReleaseFast -femit-bin=dist/phantom_kernel.wasm",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "dev": "vite --config demo/vite.config.ts --host 127.0.0.1",
    "demo:build": "vite build --config demo/vite.config.ts",
    "demo:preview": "vite preview --config demo/vite.config.ts --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "bench": "vitest bench",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "ci": "npm run typecheck && npm run lint && npm test && npm run build && npm run build:wasm"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
